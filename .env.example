# Neon Postgres — get from https://neon.tech
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Better Auth — generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Cloudflare — wrangler login, then read from `wrangler whoami`
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare R2 (mosque photos)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=qibla-photos
R2_PUBLIC_URL=

# Google Maps (Android is required; iOS optional if using Apple Maps)
GOOGLE_MAPS_API_KEY_ANDROID=
GOOGLE_MAPS_API_KEY_IOS=

# Expo mobile app — points to deployed admin / backend
EXPO_PUBLIC_API_URL=http://localhost:3000

# Admin (Vite client)
VITE_APP_URL=http://localhost:3000
